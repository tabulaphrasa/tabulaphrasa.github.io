---
import { type CollectionEntry } from "astro:content";
import PostCard from "@/components/blog/PostCard.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

const MAX_POSTS = 20;
const allPosts = await getAllPosts();
const allPostsByDate = allPosts.sort(collectionDateSort) as CollectionEntry<"post">[];
const latestPosts = allPostsByDate.slice(0, MAX_POSTS);
---

<PageLayout meta={{ title: "Start" }}>
	<section class="mb-12">
		<h1 class="title mb-4">tabulaphrasa</h1>
		<p class="text-muted max-w-2xl">
			Blog — Platzhalter-Intro, wird spaeter angepasst.
		</p>
	</section>

	{
		latestPosts.length > 0 ? (
			<section class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
				{latestPosts.map((p) => (
					<PostCard post={p} />
				))}
			</section>
		) : (
			<section class="text-muted">
				<p>Noch keine Beitraege. Bald mehr.</p>
			</section>
		)
	}
</PageLayout>
