---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import FormattedDate from "@/components/FormattedDate.astro";

type Props = {
	post: CollectionEntry<"post">;
};

const { post } = Astro.props;
---

<a
	href={`/posts/${post.id}/`}
	class="group border-border hover:border-accent bg-bgColor focus-visible:ring-accent flex h-full flex-col overflow-hidden rounded-md border transition-colors focus:outline-none focus-visible:ring-2"
>
	{
		post.data.coverImage && (
			<div class="aspect-[16/10] w-full overflow-hidden bg-muted/20">
				<Image
					src={post.data.coverImage.src}
					alt={post.data.coverImage.alt}
					width={640}
					height={400}
					class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
				/>
			</div>
		)
	}
	<div class="flex flex-1 flex-col gap-2 p-4">
		<FormattedDate class="text-muted text-xs" date={post.data.publishDate} />
		<h3 class="text-accent line-clamp-2 text-base font-semibold leading-tight">
			{post.data.draft && <span class="text-red-500">(Entwurf) </span>}
			{post.data.title}
		</h3>
		<p class="text-muted line-clamp-3 text-sm">{post.data.description}</p>
	</div>
</a>
